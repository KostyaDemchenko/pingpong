# copy to .env and fill in — .env is gitignored, never commit it

# wss:// hostname of the signaling relay (Cloudflare: proxied is OK)
DOMAIN=relay.pixel-pong.online

# TURN hostname — MUST be a DNS-only (grey cloud) record pointing straight at
# the VPS IP: Cloudflare's proxy cannot carry TURN traffic
TURN_DOMAIN=turn.pixel-pong.online

# Cloudflare API token with Zone -> DNS -> Edit permission for the zone
# (My Profile -> API Tokens -> Create Token -> "Edit zone DNS" template)
CF_API_TOKEN=put-your-token-here

# TURN credentials — the same values go into Vercel's VITE_TURN_USER/PASS
TURN_USER=pong
TURN_PASS=put-a-long-random-password-here
